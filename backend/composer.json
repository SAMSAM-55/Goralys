{
  "name": "goralys/goralys",
  "description": "A simple web app to help french high-schools to manage subjects for the 'Grand Oral'",
  "license": ["AGPL-3.0-or-later"],

    "require": {
      "ext-json": "*",
      "ext-mysqli": "*",
        "vlucas/phpdotenv": "^5.6",
      "ext-zip": "*",
        "dompdf/dompdf": "^3.1",
      "ext-fileinfo": "*"
    },

  "autoload": {
    "psr-4": {
      "Goralys\\": "./src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Goralys\\Tests\\": "./tests"
    }
  },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "squizlabs/php_codesniffer": "3.*"
    },
  "scripts": {
    "phpunit": "vendor/bin/phpunit",
    "phpcs": [
      "vendor/bin/phpcbf --standard=PSR12 --ignore=vendor/* . || true && vendor/bin/phpcs --standard=PSR12 --ignore=vendor/* ."
    ]
  }
}
